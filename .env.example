# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM provider ---
# LLM_PROVIDER picks which backend src/agent.py and src/reasoning.py use.
# Leave it unset to auto-select: OpenAI if OPENAI_API_KEY is set, else Ollama.
#   openai | needs OPENAI_API_KEY
#   ollama | needs a local `ollama serve` running, no API key
LLM_PROVIDER=

# Option A: OpenAI API (recommended for quality)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Option B: local Ollama (no key needed; run `ollama serve` first)
OLLAMA_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2:latest

# --- Observability (optional) ---
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
